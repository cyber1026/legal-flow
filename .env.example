# Legal Flow 公开环境变量示例。
# 复制为 `.env` 后填写真实密钥；不要把 `.env` 提交到仓库。

APP_NAME=Legal Flow
ENVIRONMENT=development

# LLM：项目默认示例使用 DeepSeek v4。
LLM_PROVIDER=deepseek
LLM_TEMPERATURE=0.2
LLM_REQUEST_TIMEOUT=120
LLM_REVIEW_TIMEOUT=240
LLM_MAX_RETRIES=2

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_BETA_BASE_URL=https://api.deepseek.com/beta
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_ENABLE_THINKING=true

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-3-flash-preview

ZHIPUAI_API_KEY=
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPUAI_MODEL=glm-4.6v-flash
ZHIPUAI_ENABLE_THINKING=true

# Query rewriter：留空时沿用主模型配置。
REWRITER_PROVIDER=
REWRITER_MODEL=
REWRITER_MIN_LENGTH=8

# 检索与 embedding。
MILVUS_URI=http://localhost:19530
EMBEDDING_BASE_URL=http://localhost:7997
EMBEDDING_MODEL=models/bge-m3
EMBEDDING_DIM=1024
TOP_K=5

# 法律知识库。
LAW_COLLECTION_NAME=law_chunks
LAW_RAW_DIR=data/raw
LAW_PARSED_DIR=data/parsed_chunks
KB_CHUNKS_DIR=data/legal_sources/_normalized/chunks
KB_RETRIEVE_TOP_K=5
KB_RETRIEVE_FETCH_K=20
KB_RETRIEVE_TIMEOUT=30
KB_SUMMARIZE_TIMEOUT=45
KB_FULLTEXT_MAX_CHARS=120000

# 合同审查。
CONTRACT_COLLECTION_NAME=contract_chunks
CONTRACT_RAW_DIR=data/contracts/raw
CONTRACT_MAX_CLAUSES=200
REVIEW_CONCURRENCY=4
REVIEW_SKIP_BOILERPLATE=false
CONTRACT_MAX_UPLOAD_MB=20
PADDLEOCR_LANG=ch
PADDLEOCR_USE_GPU=true
DOCLING_ARTIFACTS_PATH=ckpts/docling_artifacts

# 数据库与认证。
POSTGRES_USER=legal_flow
POSTGRES_PASSWORD=change-me-local-postgres-password
POSTGRES_DB=legal_flow
DATABASE_URL=postgresql://legal_flow:change-me-local-postgres-password@localhost:5432/legal_flow
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
CHECKPOINTER_POOL_MAX_SIZE=10
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# 日志与 tracing。
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_TO_FILE=true
LOG_FILE_MAX_MB=10
LOG_FILE_BACKUP_COUNT=5

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=legal-flow
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Docker Compose 本地依赖服务。
MINIO_ROOT_USER=legal-flow-minio
MINIO_ROOT_PASSWORD=change-me-local-minio-password
EMBEDDING_MODEL_DIR=./models
